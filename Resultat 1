body {
    margin: 0;
    font-family: Arial, sans-serif;
}

/* NAVBAR */
header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: black;
    color: white;
    padding: 15px 30px;
}

nav a {
    color: white;
